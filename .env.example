APP_NAME=LocustHub
API_PREFIX=/api/v1
DEMO_TOKEN=dev-token
PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1
PUBLIC_ADMIN_BASE_URL=http://127.0.0.1:8080

# Local development defaults
DATABASE_BACKEND=sqlite
DATABASE_PATH=data/locusthub.db
ARTIFACT_STORAGE_PROVIDER=local
ARTIFACT_ROOT=artifacts

# MySQL deployment
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=locusthub
MYSQL_PASSWORD=locusthub
MYSQL_DATABASE=locusthub

# Aliyun OSS deployment
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_SIGNED_URL_EXPIRE_SECONDS=900

# Stage 3 Kubernetes + Locust runtime
LANE_RUNTIME_BACKEND=local
LANE_NAMESPACE_STRATEGY=tenant
KUBERNETES_APPLY_ENABLED=false
LOCUST_IMAGE=locustio/locust:latest
LOCUST_MASTER_WEB_PORT=8089
LOCUST_MASTER_BIND_PORT=5557
LOCUST_MASTER_BIND_PORT_PLUS_ONE=5558
LOCUST_METRICS_BACKEND=simulated
LOCUST_MASTER_BASE_URL_TEMPLATE=http://{run_id}-master.{namespace}.svc.cluster.local:8089
LOCUST_API_TIMEOUT_SECONDS=5.0
