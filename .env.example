APP_NAME=LocustHub
API_PREFIX=/api/v1
DEMO_TOKEN=dev-token

# Local development defaults
DATABASE_BACKEND=sqlite
DATABASE_PATH=data/locusthub.db
ARTIFACT_STORAGE_PROVIDER=local
ARTIFACT_ROOT=artifacts

# MySQL deployment
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=locusthub
MYSQL_PASSWORD=locusthub
MYSQL_DATABASE=locusthub

# Aliyun OSS deployment
ALIYUN_OSS_ENDPOINT=
ALIYUN_OSS_BUCKET=
ALIYUN_OSS_ACCESS_KEY_ID=
ALIYUN_OSS_ACCESS_KEY_SECRET=
ALIYUN_OSS_SIGNED_URL_EXPIRE_SECONDS=900
